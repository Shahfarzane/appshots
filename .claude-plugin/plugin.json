{
  "name": "appshots",
  "version": "0.2.0",
  "description": "Capture macOS app context for Claude Code and coding agents. Takes screenshot + accessibility tree snapshots and stores them for reference by CLI and MCP tools.",
  "author": {
    "name": "Shah Farzane",
    "email": "hey@nerd.ceo",
    "url": "https://github.com/Shahfarzane"
  },
  "homepage": "https://github.com/Shahfarzane/appshots",
  "repository": "https://github.com/Shahfarzane/appshots",
  "license": "MIT",
  "keywords": [
    "appshot",
    "screenshot",
    "accessibility",
    "context",
    "macOS",
    "capture"
  ],
  "mcpServers": {
    "appshots": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/appshotsctl",
      "args": [
        "mcp"
      ]
    }
  }
}
